# Promptly Environment Variables Example

# Server listening port
PORT=5000

# MongoDB connection string (local fallback provided)
MONGO_URI=mongodb://localhost:27017/promptly

# JWT Secret key for authentication token encoding
JWT_SECRET=promptly_default_secret_key

# Gemini API Key (get from Google AI Studio). If empty, Promptly will fall back to smart offline mock prompt generation.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
